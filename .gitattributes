# Normalize line endings across platforms.
* text=auto

# Files executed or read inside Linux containers MUST stay LF, otherwise a
# CRLF checkout (e.g. on Windows) breaks the shell script / configs.
*.sh        text eol=lf
*.conf      text eol=lf
*.sql       text eol=lf
Dockerfile  text eol=lf

# Treat these as binary (no line-ending or diff munging).
*.png  binary
*.jpg  binary
*.docx binary
*.joblib binary
